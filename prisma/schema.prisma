// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  name              String?
  image             String?
  role              Role                    @default(USER)
  isActive          Boolean                 @default(true)
  isBlocked         Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  ticketsSold       Ticket[]                @relation("SellerTickets")
  ticketsBought     Ticket[]                @relation("BuyerTickets")
  messages          Message[]
  loungeMessages    LoungeMessage[]
  ticketThreadReads TicketThreadReadState[]
}

model Ticket {
  id                String                  @id @default(cuid())
  code              String                  @unique
  title             String
  sellerPhone       String?
  description       String?
  status            TicketStatus            @default(AVAILABLE)
  isActive          Boolean                 @default(true)
  sellerId          String
  buyerId           String?
  seller            User                    @relation("SellerTickets", fields: [sellerId], references: [id])
  buyer             User?                   @relation("BuyerTickets", fields: [buyerId], references: [id])
  messages          Message[]
  threadReadStates  TicketThreadReadState[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

/// Última lectura por usuario e hilo (comprador / vendedor) en un ticket. No aplica al chat general (lounge).
model TicketThreadReadState {
  id         String        @id @default(cuid())
  userId     String
  ticketId   String
  thread     MessageThread
  lastReadAt DateTime
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket     Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([userId, ticketId, thread])
  @@index([userId])
}

/// Comprador ↔ admin (pago, escrow). Vendedor ↔ admin en SELLER_SIDE.
enum MessageThread {
  BUYER_SIDE
  SELLER_SIDE
}

model Message {
  id        String        @id @default(cuid())
  text      String
  isSystem  Boolean       @default(false)
  isActive  Boolean       @default(true)
  thread    MessageThread @default(BUYER_SIDE)
  senderId  String
  ticketId  String
  sender    User          @relation(fields: [senderId], references: [id])
  ticket    Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

/// Chat público de la comunidad (lectura para todos; escribir solo con sesión).
model LoungeMessage {
  id        String   @id @default(cuid())
  text      String
  isActive  Boolean  @default(true)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())
}

enum TicketStatus {
  AVAILABLE
  IN_PROGRESS
  COMPLETED
}

enum Role {
  ADMIN
  USER
}
